# ============================================================================
# SRIBEESonline FastAPI Backend - Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment
# For production, use strong secrets and secure credentials

# Application
APP_NAME=SRIBEESonline API
APP_ENV=development  # development | staging | production
DEBUG=true
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================================================
# Error Tracking & Monitoring (Sentry)
# ============================================================================
# Get DSN from https://sentry.io - Required for production
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ============================================================================
# PostgreSQL Database
# ============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sribeesonline
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Legacy format (alternative configuration)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sribeesonline
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
MAIL_FROM=noreply@sribeesonline.lk
MAIL_FROM_NAME=SRIBEESonline
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Firebase Cloud Messaging (Push Notifications)
FIREBASE_CREDENTIALS_PATH=
FCM_SERVER_KEY=

# CORS (JSON array format)
CORS_ORIGINS=["http://localhost:3001", "http://localhost:19006", "http://localhost:8081"]
FRONTEND_URL=http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_PASSWORD_RESET_PER_HOUR=3

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=
